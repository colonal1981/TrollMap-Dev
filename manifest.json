{
  "name": "TrollMap GPX Studio — Carolinas Master Edition",
  "short_name": "TrollMap",
  "description": "Precision trolling route planner, lake/river trip planning, live utility and kayak safety dashboard.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#0b1623",
  "theme_color": "#0b1623",
  "icons": [
    {
      "src": "./icons/icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "./icons/icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "catch_photo",
          "accept": ["image/jpeg", "image/png", "image/heic", "image/*"]
        }
      ]
    }
  }
}
